# NetBird API credentials (local / stdio mode)
# Create a service user in the NetBird dashboard and issue a Personal Access Token for it.
NETBIRD_API_TOKEN=nb_pat_xxxxxxxxxxxxxxxxxxxx

# NetBird API base URL. Default is NetBird Cloud. Point this at your own host for self-hosted.
NETBIRD_API_URL=https://api.netbird.io

# Extra hosts a request-supplied NetBird base URL is allowed to target (comma-separated).
# The NETBIRD_API_URL host above is always allowed; add more here only if you accept
# per-request base URLs for several self-hosted instances.
NETBIRD_ALLOWED_API_HOSTS=

# Enable destructive tools (delete_peer, delete_policy, delete_group). Off by default in v1.
NETBIRD_ENABLE_DESTRUCTIVE=false

# HTTP (cloud) mode only:
PORT=3000
# Externally reachable origin the OAuth server advertises in its metadata.
# REQUIRED in production (must be https). Defaults to http://localhost:PORT for local testing.
PUBLIC_BASE_URL=https://netbird-mcp.example.com

# OAuth 2.1 (what Claude uses as a remote connector). On by default in HTTP mode.
NETBIRD_ENABLE_OAUTH=true
# Verify the pasted NetBird PAT with a live read during the OAuth login. Set false for offline dev.
NETBIRD_VERIFY_PAT_ON_LOGIN=true

# Direct-PAT fallback (handy for testing; Claude itself uses OAuth above).
# OFF by default while OAuth is on — enable it explicitly here. It turns on
# automatically when NETBIRD_ENABLE_OAUTH=false (the only auth path then).
# When on, the request base URL must be allowlisted and the PAT is verified.
NETBIRD_ENABLE_DIRECT_PAT=false
# Header the hosted server reads the caller's NetBird PAT from (per-request, never stored).
NETBIRD_TOKEN_HEADER=x-netbird-token
# Optional header for per-tenant API base URL override.
NETBIRD_URL_HEADER=x-netbird-api-url

# Logging: debug | info | warn | error
LOG_LEVEL=info
